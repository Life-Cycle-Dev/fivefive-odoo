<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_five_five_product_convert_cost_wizard_form" model="ir.ui.view">
		<field name="name">five.five.product.convert.cost.wizard.form</field>
		<field name="model">five.five.product.convert.cost.wizard</field>
		<field name="arch" type="xml">
			<form string="Edit Costs">
				<group string="Convert Line">
					<field name="convert_wizard_line_id" invisible="1"/>
					<field name="product_variant_id" readonly="1"/>
					<field name="quantity" readonly="1"/>
					<field name="quality_note" readonly="1"/>
				</group>
				<group>
					<field name="cost_line_ids">
						<list editable="bottom">
							<field name="cost_name"/>
							<field name="cost"/>
							<field name="type"/>
						</list>
					</field>
				</group>
				<footer>
					<button name="action_confirm" type="object" string="Apply" class="btn-primary"/>
					<button special="cancel" string="Cancel" class="btn-secondary"/>
				</footer>
			</form>
		</field>
	</record>
</odoo>

