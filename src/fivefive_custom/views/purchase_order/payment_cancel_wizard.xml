<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_five_five_purchase_order_payment_cancel_wizard_form" model="ir.ui.view">
		<field name="name">five.five.purchase.order.payment.cancel.wizard.form</field>
		<field name="model">five.five.purchase.order.payment.cancel.wizard</field>
		<field name="arch" type="xml">
			<form string="ยกเลิก Payment">
				<group>
					<field name="purchase_order_id" readonly="1"/>
					<field name="payment_id" readonly="1"/>
					<field name="reason" placeholder="ระบุเหตุผลการยกเลิก..." required="1"/>
					<field name="attachment" filename="attachment_name"/>
				</group>
				<footer>
					<button name="action_confirm_cancel" type="object" string="ยืนยันยกเลิก" class="btn-danger"/>
					<button special="cancel" string="ปิด" class="btn-secondary"/>
				</footer>
			</form>
		</field>
	</record>
</odoo>
