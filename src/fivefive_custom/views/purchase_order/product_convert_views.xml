<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_five_five_product_convert_tree" model="ir.ui.view">
		<field name="name">five.five.product.convert.list</field>
		<field name="model">five.five.product.convert</field>
		<field name="arch" type="xml">
			<list>
				<field name="commercial_invoice_line_id"/>
				<field name="product_variant_id"/>
				<field name="quantity"/>
				<field name="quality_note"/>
				<field name="cost_summary" readonly="1"/>
			</list>
		</field>
	</record>

	<record id="view_five_five_product_convert_form" model="ir.ui.view">
		<field name="name">five.five.product.convert.form</field>
		<field name="model">five.five.product.convert</field>
		<field name="arch" type="xml">
			<form string="Product Convert">
				<sheet>
					<group>
						<field name="commercial_invoice_line_id" readonly="1"/>
						<field name="product_variant_id"/>
						<field name="quantity"/>
						<field name="quality_note"/>
						<field name="cost_summary" readonly="1"/>
					</group>
					<group string="Costs">
						<field name="product_cost_ids">
							<list editable="bottom">
								<field name="cost_name"/>
								<field name="cost" width="200px"/>
								<field name="type"/>
								<field name="start_calculate_cost" width="200px"/>
							</list>
						</field>
					</group>
				</sheet>
			</form>
		</field>
	</record>

	<record id="action_five_five_product_convert" model="ir.actions.act_window">
		<field name="name">Converted Products</field>
		<field name="res_model">five.five.product.convert</field>
		<field name="view_mode">list,form</field>
	</record>
</odoo>

