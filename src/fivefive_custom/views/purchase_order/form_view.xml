<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_five_five_purchase_order_model_form" model="ir.ui.view">
		<field name="name">five.five.purchase.order.form</field>
		<field name="model">five.five.purchase.order</field>
		<field name="arch" type="xml">
			<form>
				<sheet>
					<group>
						<group>
							<field name="supplier"/>
						</group>
						<group>
							<field name="total_amount" readonly="1"/>
							<field name="amount_paid"/>
							<field name="balance_amount" readonly="1"/>
						</group>
					</group>

					<notebook>
						<page string="Commercial Invoice Lines">
							<field name="commercial_invoice_line_ids">
								<list editable="bottom">
									<field name="name"/>
									<field name="unit"/>
									<field name="size"/>
									<field name="grade"/>
									<field name="unit_price"/>
									<field name="quantity"/>
									<field name="total_price" readonly="1"/>
								</list>
							</field>
						</page>
					</notebook>
				</sheet>
				<chatter>
					<field name="message_follower_ids"/>
					<field name="activity_ids"/>
					<field name="message_ids" options="{'post_refresh': 'recipients'}"/>
				</chatter>
			</form>
		</field>
	</record>

	<record id="action_five_five_purchase_order_model" model="ir.actions.act_window">
		<field name="name">Purchase Orders</field>
		<field name="res_model">five.five.purchase.order</field>
		<field name="view_mode">list,form</field>
	</record>
</odoo>
