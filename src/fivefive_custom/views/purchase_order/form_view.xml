<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_five_five_purchase_order_model_form" model="ir.ui.view">
		<field name="name">five.five.purchase.order.form</field>
		<field name="model">five.five.purchase.order</field>
		<field name="arch" type="xml">
			<form duplicate="false" delete="false" class="ff_five_five_purchase_order">
					<header>
						<button name="action_po_issue" string="Issue" type="object" class="btn-primary" invisible="state != 'draft'"/>
						<button name="action_cancel" string="Cancel" type="object" class="btn-danger" invisible="state != 'draft'"/>
						<button name="action_post" string="Post" type="object" class="btn-primary" invisible="state != 'po_issued'"/>
						<button name="action_pay" string="Pay" type="object" class="btn-primary" invisible="state not in ['documents_completed', 'clearing']"/>
						<button name="action_reset_to_draft" string="Reset to draft" type="object" class="btn-secondary" invisible="state not in ['documents_completed', 'po_issued']"/>
						<field name="state" widget="statusbar" statusbar_visible="draft,po_issued,documents_completed,clearing,closed,cancelled"/>
					</header>
				<sheet>
					<div class="oe_title">
						<h1>
							<field name="number" readonly="1"/>
						</h1>
					</div>
					<group>
						<group>
							<field name="reason_cancel" class="text-danger" placeholder="Reason for Cancel" readonly="1" invisible="state != 'cancelled'"/>
							<field name="supplier_id" placeholder="Select a supplier..." readonly="state not in ['draft', 'po_issued']"/>
						</group>
						<group>
							<field name="shipment_container_no" invisible="state in ['draft']"/>
							<field name="bl_no" invisible="state in ['draft']"/>
							<field name="arrived_at" invisible="state in ['draft']"/>
						</group>
					</group>

					<group>
						<group string="Contact">
							<field name="supplier_name" string="Name" readonly="state not in ['draft', 'po_issued']"/>
							<field name="supplier_tax_id" string="Tax ID" readonly="state not in ['draft', 'po_issued']"/>
							<field name="supplier_contact" string="Contact" readonly="state not in ['draft', 'po_issued']"/>
							<field name="supplier_phone" string="Phone" readonly="state not in ['draft', 'po_issued']"/>
						</group>
						<group string="Bank account">
							<field name="supplier_account_name" string="Account name" readonly="state not in ['draft', 'po_issued']"/>
							<field name="supplier_account_number" string="Account number" readonly="state not in ['draft', 'po_issued']"/>
							<field name="supplier_account_bank_name" string="Bank name" readonly="state not in ['draft', 'po_issued']"/>
							<field name="supplier_account_bank_address" string="Bank address" readonly="state not in ['draft', 'po_issued']"/>
							<field name="supplier_account_bank_swift_code" string="SWIFT code" readonly="state not in ['draft', 'po_issued']"/>
						</group>
					</group>

					<notebook>
						<page string="Commercial Invoice Lines">
							<field name="commercial_invoice_line_ids" readonly="state not in ['draft', 'po_issued']">
								<list editable="bottom" class="ff_confirm_list_delete">
									<field name="name" width="200px"/>
									<field name="unit_id" width="100px"/>
									<field name="size_id" width="100px"/>
									<field name="grade_id" width="100px"/>
									<field name="unit_price_usd"/>
									<field name="quantity"/>
									<field name="total_price_usd" readonly="1"/>
								</list>
							</field>
						</page>
						<page string="Documents">
							<field name="document_ids" readonly="state not in ['draft', 'po_issued']">
								<list editable="bottom" class="ff_confirm_list_delete">
									<field name="number"/>
									<field name="attachment_name" string="Name"/>
									<field name="type"/>
									<field
										name="attachment_file"
										filename="attachment_name"
										string="Upload"
									/>
									<button
										name="action_download_document_file"
										type="object"
										string="Download"
										class="btn-link"
										icon="fa-download"
										invisible="not attachment_file"
									/>
								</list>
							</field>
						</page>
							<page string="Payment">
								<field name="payment_ids" readonly="1">
									<list decoration-danger="is_cancel" decoration-success="not is_cancel">
										<field name="pay_at" width="200px"/>
										<field name="amount_usd" width="100px"/>
										<field name="amount_thb" width="100px"/>
										<field name="note" width="200px"/>
										<field name="cancel_reason" width="200px"/>
										<button
											name="action_open_cancel_payment_wizard"
											type="object"
											string="Cancel Payment"
											class="btn-link text-danger"
											icon="fa-ban"
											invisible="is_cancel or is_reversed"
										/>
									</list>
								</field>
							</page>
					</notebook>

					<group class="mt-4">
						<group class="ms-auto">

						</group>
						<group class="ms-auto ff_po_totals">
							<field name="total_amount_usd" readonly="1" class="text-end"/>
							<field name="amount_paid_usd" readonly="1" class="text-end"/>
							<field name="amount_paid_thb" readonly="1" class="text-end"/>
							<field name="balance_amount_usd" readonly="1" class="text-end"/>
						</group>
					</group>
				</sheet>
				<chatter>
					<field name="message_follower_ids"/>
					<field name="activity_ids"/>
					<field name="message_ids" options="{'post_refresh': 'recipients'}"/>
				</chatter>
			</form>
		</field>
	</record>

	<record id="action_five_five_purchase_order_model" model="ir.actions.act_window">
		<field name="name">Purchase Orders</field>
		<field name="res_model">five.five.purchase.order</field>
		<field name="view_mode">list,form</field>
	</record>
</odoo>
