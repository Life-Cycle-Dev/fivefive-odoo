<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_five_five_purchase_order_model_form" model="ir.ui.view">
		<field name="name">five.five.purchase.order.form</field>
		<field name="model">five.five.purchase.order</field>
		<field name="arch" type="xml">
			<form>
				<sheet>
					<group>
						<group>
							<field name="supplier_id" placeholder="Select a supplier..."/>
						</group>
					</group>

					<group>
						<group string="Contact">
							<field name="supplier_name" string="Name"/>
							<field name="supplier_tax_id" string="Tax ID"/>
							<field name="supplier_contact" string="Contact"/>
							<field name="supplier_phone" string="Phone"/>
						</group>
						<group string="Bank account">
							<field name="supplier_account_name" string="Account name"/>
							<field name="supplier_account_number" string="Account number"/>
							<field name="supplier_account_bank_name" string="Bank name"/>
							<field name="supplier_account_bank_address" string="Bank address"/>
							<field name="supplier_account_bank_swift_code" string="SWIFT code"/>
						</group>
					</group>

					<notebook>
						<page string="Commercial Invoice Lines">
							<field name="commercial_invoice_line_ids">
								<list editable="bottom">
									<field name="name" width="200px"/>
									<field name="unit_id" width="100px"/>
									<field name="size_id" width="100px"/>
									<field name="grade_id" width="100px"/>
									<field name="unit_price"/>
									<field name="quantity"/>
									<field name="total_price" readonly="1"/>
								</list>
							</field>
						</page>
					</notebook>

					<group class="mt-4">
						<group class="ms-auto">

						</group>
						<group class="ms-auto ff_po_totals">
							<field name="total_amount" readonly="1" class="text-end"/>
							<field name="amount_paid" readonly="1" class="text-end"/>
							<field name="balance_amount" readonly="1" class="text-end"/>
						</group>
					</group>
				</sheet>
				<chatter>
					<field name="message_follower_ids"/>
					<field name="activity_ids"/>
					<field name="message_ids" options="{'post_refresh': 'recipients'}"/>
				</chatter>
			</form>
		</field>
	</record>

	<record id="action_five_five_purchase_order_model" model="ir.actions.act_window">
		<field name="name">Purchase Orders</field>
		<field name="res_model">five.five.purchase.order</field>
		<field name="view_mode">list,form</field>
	</record>
</odoo>
