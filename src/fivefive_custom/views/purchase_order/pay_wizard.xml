<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_five_five_purchase_order_pay_wizard_form" model="ir.ui.view">
		<field name="name">five.five.purchase.order.payment.wizard.form</field>
		<field name="model">five.five.purchase.order.payment.wizard</field>
		<field name="arch" type="xml">
			<form string="ทำเรื่องการจ่ายเงิน PO">
				<group>
					<field name="purchase_order_id" readonly="1"/>
					<field name="amount_usd"/>
					<field name="amount_thb"/>
					<field name="pay_at"/>
					<field name="note"/>
					<field name="attachment"/>
				</group>
				<footer>
					<button name="action_confirm" type="object" string="ยืนยัน" class="btn-primary"/>
					<button special="cancel" string="ปิด" class="btn-secondary"/>
				</footer>
			</form>
		</field>
	</record>
</odoo>
