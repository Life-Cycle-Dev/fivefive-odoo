<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_five_five_commercial_invoice_line_convert_wizard_form" model="ir.ui.view">
		<field name="name">five.five.commercial.invoice.line.convert.wizard.form</field>
		<field name="model">five.five.commercial.invoice.line.convert.wizard</field>
		<field name="arch" type="xml">
			<form string="Convert to Product">
				<group string="Invoice Line">
					<group>
						<field name="commercial_invoice_line_id" invisible="1"/>
						<field name="commercial_invoice_line_name" readonly="1"/>
					</group>
					<group>
						<field name="commercial_invoice_unit_id" readonly="1"/>
						<field name="commercial_invoice_size_id" readonly="1"/>
						<field name="commercial_invoice_grade_id" readonly="1"/>
						<field name="commercial_invoice_quantity" readonly="1"/>
					</group>
				</group>
				<group string="Products to convert">
					<button name="action_open_add_convert_line_wizard" type="object" string="Add line" class="btn-primary"/>
					<field name="convert_line_ids">
						<list create="0" edit="0">
							<field name="product_variant_id"/>
							<field name="quantity"/>
							<field name="quality_note"/>
							<button name="action_open_edit_convert_line_wizard" type="object" string="Edit" class="btn-secondary"/>
							<button name="action_open_cost_wizard" type="object" string="Costs" class="btn-secondary"/>
							<field name="cost_summary" readonly="1"/>
						</list>
					</field>
				</group>
				<footer>
					<button name="action_confirm" type="object" string="Confirm" class="btn-primary"/>
					<button special="cancel" string="Cancel" class="btn-secondary"/>
				</footer>
			</form>
		</field>
	</record>
</odoo>

