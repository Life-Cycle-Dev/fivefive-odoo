<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_five_five_supplier_model_form" model="ir.ui.view">
        <field name="name">five.five.supplier.form</field>
        <field name="model">five.five.supplier</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <div class="oe_title">
                                <div class="text-muted" invisible="name == '' or not name">Supplier</div>
                                <h1 invisible="not active or name == '' or not name">
                                    <field name="name" readonly="1"/>
                                </h1>
                                <h1 class="text-decoration-line-through text-muted" invisible="active or name == '' or not name">
                                    <field name="name" readonly="1"/>
                                </h1>
                            </div>
                        </group>
                        <group>
                            <field nolabel="1" name="image" widget="image" class="oe_avatar" options="{'size': [128, 128]}"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="General Information">
                            <field name="name"/>
                            <field name="tax_id"/>
                        </group>
                        <group string="Contact Information">
                            <field name="contact"/>
                            <field name="phone"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Bank Information">
                            <group>
                                <group>
                                    <field name="account_name"/>
                                    <field name="account_number"/>
                                </group>
                                <group>
                                    <field name="account_bank_name"/>
                                    <field name="account_bank_swift_code"/>
                                </group>
                                <field name="account_bank_address" colspan="2"/>
                            </group>
                        </page>
                        <page string="Audit Log">
                            <group>
                                <field name="create_uid" readonly="1"/>
                                <field name="create_date" readonly="1"/>
                                <field name="write_uid" readonly="1"/>
                                <field name="write_date" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="action_five_five_supplier_model" model="ir.actions.act_window">
        <field name="name">Supplier</field>
        <field name="res_model">five.five.supplier</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>