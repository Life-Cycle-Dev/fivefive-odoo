<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_five_five_purchase_order_document_upload_wizard_form" model="ir.ui.view">
		<field name="name">five.five.purchase.order.document.upload.wizard.form</field>
		<field name="model">five.five.purchase.order.document.upload.wizard</field>
		<field name="arch" type="xml">
			<form string="Upload file">
				<group>
					<field name="document_id" invisible="1"/>
					<field name="upload_filename" string="File name"/>
					<field name="upload_file" filename="upload_filename" string="File"/>
				</group>
				<footer>
					<button name="action_apply_upload" type="object" string="Upload" class="btn-primary"/>
					<button special="cancel" string="Cancel" class="btn-secondary"/>
				</footer>
			</form>
		</field>
	</record>
</odoo>
