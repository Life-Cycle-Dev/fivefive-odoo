<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_five_five_purchase_order_document_model_form" model="ir.ui.view">
		<field name="name">five.five.purchase.order.document.form</field>
		<field name="model">five.five.purchase.order.document</field>
		<field name="arch" type="xml">
			<form>
				<sheet>
					<group>
						<field name="purchase_order_id" readonly="1"/>
						<field name="type" readonly="1"/>
						<field name="attachment_name" string="File name" readonly="1"/>
						<div class="d-flex gap-2">
							<button
								name="action_open_upload_wizard"
								type="object"
								string="Upload"
								class="btn-link"
								icon="fa-upload"
							/>
							<button
								name="action_download_document_file"
								type="object"
								string="Download"
								class="btn-link"
								icon="fa-download"
								invisible="not attachment_file"
							/>
						</div>
						<field name="attachment_file" invisible="1"/>
					</group>
				</sheet>
			</form>
		</field>
	</record>

    <record id="action_five_five_purchase_order_document_model" model="ir.actions.act_window">
		<field name="name">Purchase Orders Document</field>
		<field name="res_model">five.five.purchase.order.document</field>
		<field name="view_mode">list,form</field>
	</record>
</odoo>