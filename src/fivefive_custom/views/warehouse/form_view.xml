<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_five_five_warehouse_model_form" model="ir.ui.view">
        <field name="name">five.five.warehouse.form</field>
        <field name="model">five.five.warehouse</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <div class="oe_title">
                                <div class="text-muted" invisible="name == '' or not name">Warehouse</div>
                                <h1 invisible="not active or name == '' or not name">
                                    <field name="name" readonly="1"/>
                                </h1>
                                <h1 class="text-decoration-line-through text-muted" invisible="active or name == '' or not name">
                                    <field name="name" readonly="1"/>
                                </h1>
                            </div>
                        </group>
                        <group>
                            <field nolabel="1" name="image" widget="image" class="oe_avatar" options="{'size': [128, 128]}"/>
                        </group>
                    </group>

                    <group string="General Information">
                        <field name="name"/>
                        <field name="code"/>
                        <field name="phone"/>
                        <field name="address"/>
                        <field name="active"/>
                    </group>

                    <group string="Inventory">
                        <field name="inventory_ids" nolabel="1" context="{'active_test': False}">
                            <list editable="bottom" class="ff_confirm_list_delete">
                                <field name="product_variant_id"/>
                                <field name="lot_number"/>
                                <field name="quantity"/>
                                <field name="quality_note"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="action_five_five_warehouse_model" model="ir.actions.act_window">
        <field name="name">Warehouse</field>
        <field name="res_model">five.five.warehouse</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
