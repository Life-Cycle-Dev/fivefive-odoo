<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_five_five_product_model_form" model="ir.ui.view">
        <field name="name">five.five.product.product.form</field>
        <field name="model">five.five.product.product</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="unit_id"/>
                        </group>
                        <group>
                            <field nolabel="1" name="image" widget="image" class="oe_avatar" options="{'size': [128, 128]}"/>
                        </group>
                    </group>

                    <group string="Product variant">
                        <field name="variant_ids" nolabel="1" context="{'active_test': False}">
                            <list editable="bottom">
                                <field name="image" width="130"/>
                                <field name="name"/>
                                <field name="sku"/>
                                <field name="size"/>
                                <field name="grade_id"/>
                                <field name="active" width="100"/>
                                <button name="action_open_form" width="80" type="object" string="Open" icon="fa-external-link"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_five_five_product_variant_model_form" model="ir.ui.view">
        <field name="name">five.five.product.variant.form</field>
        <field name="model">five.five.product.variant</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <div class="oe_title">
                                <div class="text-muted" invisible="name == '' or not sku">Product Variant</div>
                                <h1 invisible="not active or name == '' or not name">
                                    <field name="name" readonly="1"/>
                                </h1>
                                <h1 class="text-decoration-line-through text-muted" invisible="active or name == '' or not name">
                                    <field name="name" readonly="1"/>
                                </h1>
                            </div>
                        </group>   
                        <group>
                            <field nolabel="1" name="image" widget="image" class="oe_avatar" options="{'size': [128, 128]}"/>
                        </group>
                    </group>   
                    <group>
                        <field name="name"/>
                        <field name="product_id" readonly="1"/>
                        <field name="sku"/>
                        <field name="size"/>
                        <field name="grade_id"/>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_five_five_product_unit_model_form" model="ir.ui.view">
        <field name="name">five.five.product.unit.form</field>
        <field name="model">five.five.product.unit</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_five_five_product_grade_model_form" model="ir.ui.view">
        <field name="name">five.five.product.grade.form</field>
        <field name="model">five.five.product.grade</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="action_five_five_product_model" model="ir.actions.act_window">
        <field name="name">Product</field>
        <field name="res_model">five.five.product.product</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_five_five_product_variant_model" model="ir.actions.act_window">
        <field name="name">Product variant</field>
        <field name="res_model">five.five.product.variant</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_five_five_product_unit_model" model="ir.actions.act_window">
        <field name="name">Product Unit</field>
        <field name="res_model">five.five.product.unit</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_five_five_product_grade_model" model="ir.actions.act_window">
        <field name="name">Product Grade</field>
        <field name="res_model">five.five.product.grade</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
