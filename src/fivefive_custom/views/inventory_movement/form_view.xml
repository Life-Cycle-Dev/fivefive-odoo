<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_five_five_invent_moment_form" model="ir.ui.view">
        <field name="name">five.five.invent.moment.form</field>
        <field name="model">five.five.invent.moment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="1"/>
                    <group>
                        <group>
                            <div class="oe_title">
                            </div>
                        </group>
                    </group>
                    <group string="General Information">
                        <field name="product"/>
                        <field name="warehouse"/>
                        <field name="lot_number"/>
                        <field name="store"/>
                        <field name="qty"/>
                        <field name="status"/>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="action_five_five_invent_moment" model="ir.actions.act_window">
        <field name="name">Inventory Movement</field>
        <field name="res_model">five.five.invent.moment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>