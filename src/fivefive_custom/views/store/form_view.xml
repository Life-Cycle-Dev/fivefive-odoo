<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_five_five_store_model_form" model="ir.ui.view">
        <field name="name">five.five.store.form</field>
        <field name="model">five.five.store</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <div class="text-muted" invisible="name == '' or not name">Store Name</div>
                        <h1 invisible="not active or name == '' or not name">
                            <field name="name" readonly="1"/>
                        </h1>
                        <h1 class="text-decoration-line-through text-muted" invisible="active or name == '' or not name">
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group string="General Information">
                        <field name="name"/>
                        <field name="address"/>
                        <field name="phone"/>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="action_five_five_store_model" model="ir.actions.act_window">
        <field name="name">Store</field>
        <field name="res_model">five.five.store</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>